<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Natalie Daher</title>




<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Ovo&display=swap" rel="stylesheet">

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --red: #c8382a;
  --red-dark: #9e2b20;
  --red-light: #f5e8e7;
  --ink: #111110;
  --ink-soft: #3a3a38;
  --gray: #888884;
  --rule: #ddddd9;
  --white: #ffffff;
  --paper: #fafaf8;

  --f-display: 'Ovo', Georgia, serif;
  --f-serif: 'Ovo', Georgia, serif;
  --f-mono: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

html { scroll-behavior: smooth; }

body {
  background: var(--white);
  color: var(--ink);
  font-family: var(--f-serif);
  font-size: 16px;
  line-height: 1.7;
  overflow-x: hidden;
}

a { color: inherit; text-decoration: none; }

/* HEADER */
header {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  padding: 1.5rem 2.5rem;
  border-bottom: 1.5px solid var(--ink);
  position: sticky;
  top: 0;
  background: var(--white);
  z-index: 50;
}

.h-left {
  font-family: var(--f-mono);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gray);
}

.h-logo {
  font-family: var(--f-display);
  font-size: 1.05rem;
  letter-spacing: -0.01em;
  text-align: center;
}

.h-logo span { color: var(--red); }

.h-right {
  display: flex;
  gap: 1.75rem;
  justify-content: flex-end;
  list-style: none;
}

.h-right a {
  font-family: var(--f-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gray);
  transition: color 0.15s;
}

.h-right a:hover { color: var(--red); }

/* HERO */
.hero {
  border-bottom: 1.5px solid var(--ink);
}

.hero-text {
  padding: 6rem 2.5rem 5rem;
  max-width: 900px;
}

.hero-kicker {
  font-family: var(--f-mono);
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 2.5rem;
}

.hero-headline {
  font-family: var(--f-display);
  font-size: clamp(3.5rem, 6.5vw, 6.5rem);
  line-height: 0.93;
  letter-spacing: -0.03em;
  flex: 1;
  display: flex;
  align-items: center;
}

.hero-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  border-top: 1px solid var(--rule);
  padding-top: 1.5rem;
  margin-top: 2rem;
}

.hero-tagline {
  font-family: var(--f-serif);
  font-style: italic;
  font-size: 1rem;
  color: var(--ink-soft);
  max-width: 28ch;
  line-height: 1.5;
}

.hero-scroll {
  font-family: var(--f-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gray);
  writing-mode: vertical-rl;
}

.hero-right-panel {
  background: var(--red);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 3rem;
  position: relative;
  overflow: hidden;
}

.hero-right-panel::before {
  content: 'ND';
  position: absolute;
  top: -0.15em;
  left: -0.05em;
  font-family: var(--f-display);
  font-size: clamp(12rem, 22vw, 22rem);
  color: rgba(255,255,255,0.08);
  line-height: 1;
  pointer-events: none;
  letter-spacing: -0.05em;
}

.hero-stats {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  position: relative;
  z-index: 1;
}

.hero-stat-item {
  border-top: 1px solid rgba(255,255,255,0.3);
  padding-top: 1rem;
}

.stat-n {
  font-family: var(--f-display);
  font-size: 3rem;
  color: var(--white);
  line-height: 1;
}

.stat-l {
  font-family: var(--f-mono);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin-top: 0.2rem;
}

/* SECTION SHELL */
.s {
  padding: 6rem 2.5rem;
  max-width: 1300px;
  margin: 0 auto;
}

.s-label {
  font-family: var(--f-mono);
  font-size: 0.6rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--red);
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 3rem;
}

.s-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--rule);
}

.s-title {
  font-family: var(--f-display);
  font-size: clamp(2.2rem, 4vw, 3.75rem);
  line-height: 1;
  letter-spacing: -0.025em;
  margin-bottom: 3.5rem;
}

/* ABOUT */
#about { border-top: 1.5px solid var(--ink); }

.about-layout {
  display: grid;
  grid-template-columns: 5fr 3fr;
  gap: 5rem;
  align-items: start;
}

.about-body {
  font-size: 1rem;
  line-height: 1.85;
  color: var(--ink-soft);
}

.about-body p { margin-bottom: 1.25rem; }
.about-body p:last-child { margin-bottom: 0; }

.about-body a {
  color: var(--red);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.about-body a:hover { color: var(--red-dark); }

.about-body ul {
  margin: 0.5rem 0 1.25rem 0;
  padding-left: 0;
  list-style: none;
}

.about-body ul li {
  padding: 0.2rem 0;
  font-size: 0.95rem;
}

.about-aside { position: sticky; top: 90px; }

/* SKILLS + FAVORITES sidebar */
.aside-panel {
  border: 1.5px solid var(--ink);
  margin-bottom: 1rem;
  overflow: hidden;
}

.aside-panel-head {
  background: var(--ink);
  color: var(--white);
  font-family: var(--f-mono);
  font-size: 0.58rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 0.75rem 1.25rem;
}

.aside-panel-body {
  padding: 1.25rem;
}

.aside-tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.aside-tag {
  font-family: var(--f-mono);
  font-size: 0.58rem;
  letter-spacing: 0.05em;
  padding: 0.3rem 0.6rem;
  border: 1px solid var(--rule);
  color: var(--ink-soft);
}

.aside-tag.red {
  background: var(--red);
  border-color: var(--red);
  color: var(--white);
}

.faves-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.faves-list li {
  font-size: 0.82rem;
  color: var(--ink-soft);
  line-height: 1.4;
}

/* WORK */
#work { border-top: 1.5px solid var(--ink); }

.work-list { display: flex; flex-direction: column; }

.work-entry {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 2rem;
  align-items: start;
  padding: 2.5rem 0;
  border-bottom: 1px solid var(--rule);
  text-decoration: none;
  color: inherit;
  position: relative;
}

.work-entry::before {
  content: '';
  position: absolute;
  left: -2.5rem; right: -2.5rem; top: 0; bottom: 0;
  background: var(--red-light);
  opacity: 0;
  transition: opacity 0.15s;
  z-index: -1;
}

.work-entry:hover::before { opacity: 1; }

.work-num {
  font-family: var(--f-mono);
  font-size: 0.65rem;
  color: var(--red);
  padding-top: 0.3rem;
  letter-spacing: 0.05em;
  min-width: 2rem;
}

.work-pub {
  font-family: var(--f-mono);
  font-size: 0.6rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 0.5rem;
}

.work-title {
  font-family: var(--f-display);
  font-size: 1.35rem;
  letter-spacing: -0.015em;
  line-height: 1.15;
  margin-bottom: 0.5rem;
}

.work-desc {
  font-size: 0.9rem;
  color: var(--ink-soft);
  line-height: 1.6;
  max-width: 60ch;
}

.work-arrow {
  font-family: var(--f-mono);
  font-size: 0.9rem;
  color: var(--red);
  padding-top: 0.3rem;
  transition: transform 0.15s;
}

.work-entry:hover .work-arrow { transform: translate(3px, -3px); }

.work-video-entry {
  border: 1.5px solid var(--ink);
  margin-bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
}

.work-video-frame iframe {
  width: 100%;
  height: 100%;
  min-height: 280px;
  display: block;
  border: none;
}

.work-video-text {
  padding: 2.5rem;
  background: var(--ink);
  color: var(--white);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.work-video-text .work-pub { color: rgba(255,255,255,0.4); }
.work-video-text .work-title { color: var(--white); font-size: 1.5rem; }
.work-video-text .work-desc { color: rgba(255,255,255,0.6); }

.work-video-link {
  font-family: var(--f-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--red);
  margin-top: 1.5rem;
  display: inline-block;
  transition: color 0.15s;
}

.work-video-link:hover { color: var(--white); }

/* RESUME */
#resume { border-top: 1.5px solid var(--ink); }

.resume-cta-block {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 3rem;
  flex-wrap: wrap;
}

.resume-cta-text {
  font-size: 1.1rem;
  color: var(--ink-soft);
  max-width: 48ch;
  line-height: 1.7;
  font-style: italic;
}

.resume-link {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: var(--f-display);
  font-size: 0.85rem;
  letter-spacing: 0.02em;
  color: var(--white);
  background: var(--ink);
  padding: 1.1rem 2rem;
  white-space: nowrap;
  transition: background 0.15s;
  text-decoration: none;
}

.resume-link:hover { background: var(--red); }
.resume-link-arrow { font-size: 1rem; }

/* CONTACT */
#contact {
  border-top: 1.5px solid var(--ink);
  border-bottom: 1.5px solid var(--ink);
}

.contact-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 60vh;
}

.contact-left {
  padding: 5rem 3rem 5rem 0;
  border-right: 1.5px solid var(--ink);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.contact-big {
  font-family: var(--f-display);
  font-size: clamp(3rem, 5.5vw, 5.5rem);
  line-height: 0.95;
  letter-spacing: -0.03em;
  margin-bottom: 2rem;
}

.contact-big em {
  font-family: var(--f-serif);
  font-style: italic;
  color: var(--red);
  font-size: 0.85em;
}

.contact-note {
  font-size: 0.95rem;
  color: var(--ink-soft);
  max-width: 38ch;
  line-height: 1.65;
}

.contact-right {
  padding: 5rem 0 5rem 3rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.contact-row {
  display: flex;
  gap: 1.5rem;
  align-items: baseline;
  padding: 1.5rem 0;
  border-bottom: 1px solid var(--rule);
  text-decoration: none;
  color: var(--ink);
  transition: color 0.15s;
}

.contact-row:first-child { border-top: 1px solid var(--rule); }
.contact-row:hover { color: var(--red); }

.contact-row-label {
  font-family: var(--f-mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gray);
  width: 5rem;
  flex-shrink: 0;
  transition: color 0.15s;
}

.contact-row:hover .contact-row-label { color: var(--red); }
.contact-row-val { font-size: 0.95rem; }

/* FOOTER */
footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.25rem 2.5rem;
  font-family: var(--f-mono);
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gray);
  border-top: 1px solid var(--rule);
}

/* ANIMATIONS */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

.hero-kicker    { animation: fadeUp 0.7s 0.05s ease both; }
.hero-headline  { animation: fadeUp 0.7s 0.15s ease both; }
.hero-footer    { animation: fadeUp 0.7s 0.25s ease both; }
.hero-right-panel { animation: fadeUp 0.7s 0.3s ease both; }

/* ABOUT */
#about { border-top: 1.5px solid var(--ink); }

.about-layout {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 5rem;
  align-items: start;
}

.about-photo {
  position: sticky;
  top: 90px;
}

.about-photo img {
  width: 100%;
  display: block;
}

.about-body {
  font-size: 1rem;
  line-height: 1.85;
  color: var(--ink-soft);
  font-family: var(--f-mono);
}

.about-body p { margin-bottom: 1.25rem; }
.about-body p:last-child { margin-bottom: 0; }

.about-body a {
  color: var(--red);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.about-body a:hover { color: var(--red-dark); }

.about-body ul {
  list-style: disc;
  padding-left: 1.25rem;
  margin: 0.25rem 0 1.25rem;
}

.about-body ul li { padding: 0.2rem 0; font-size: 0.95rem; }

.about-highlights-label {
  font-family: var(--f-mono);
  font-size: 0.6rem;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 0.5rem;
  margin-top: 1.75rem;
}

.about-bottom {
  margin-top: 4rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
}

.about-bottom-panel {
  background: var(--white);
  padding: 2rem;
}

.about-bottom-head {
  font-family: var(--f-mono);
  font-size: 0.6rem;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--rule);
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.tag {
  font-family: var(--f-mono);
  font-size: 0.6rem;
  letter-spacing: 0.05em;
  padding: 0.3rem 0.65rem;
  border: 1px solid var(--rule);
  color: var(--ink-soft);
  text-transform: uppercase;
}

.tag.red {
  background: var(--red);
  border-color: var(--red);
  color: var(--white);
}

.faves-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.2rem 1rem;
  list-style: disc;
  padding-left: 1rem;
}

.faves-grid li {
  font-family: var(--f-mono);
  font-size: 0.8rem;
  color: var(--ink-soft);
  line-height: 1.6;
}

/* MOBILE */
@media (max-width: 800px) {
  header { grid-template-columns: 1fr 1fr; padding: 1rem 1.25rem; }
  .h-left { display: none; }
  .h-logo { text-align: left; }
  .h-right { gap: 1rem; }

  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero-text { border-right: none; border-bottom: 1.5px solid var(--ink); padding: 3rem 1.25rem; }
  .hero-right-panel { min-height: 260px; }
  .hero-stats { flex-direction: row; flex-wrap: wrap; gap: 1rem; }

  .s { padding: 4rem 1.25rem; }

  .about-layout { grid-template-columns: 1fr; gap: 2.5rem; }
  .about-photo { position: static; }
  .about-bottom { grid-template-columns: 1fr; }

  .contact-layout { grid-template-columns: 1fr; min-height: auto; }
  .contact-left { border-right: none; padding: 3rem 0 2rem; }
  .contact-right { padding: 0 0 3rem; }

  .work-video-entry { grid-template-columns: 1fr; }
  .work-video-frame { display: none; }

  .work-entry { grid-template-columns: auto 1fr; }
  .work-arrow { display: none; }

  .resume-cta-block { flex-direction: column; align-items: flex-start; }

  footer { flex-direction: column; gap: 0.4rem; text-align: center; }
}
</style>
</head>
